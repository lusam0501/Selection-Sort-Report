<!DOCTYPE html>
<html lang="zh-tw">
<head>
<meta charset="UTF-8">
<title>Merge Sort 示範</title>
<style>
/* 直接沿用你的樣式 */
body {
    font-family: 'Segoe UI';
    background: #1a1a1a;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}
.container {
    background: #000;
    padding: 20px;
    border-radius: 10px;
}
.array-container {
    display: flex;
    align-items: end;
    height: 300px;
}
.bar {
    width: 30px;
    margin: 2px;
    background: #666;
    text-align: center;
}
.bar.active { background: yellow; }
.bar.sorted { background: green; }
</style>
</head>
<body>

<div class="container">
    <h1>Merge Sort 示範</h1>
    <div id="array-container" class="array-container"></div>
    <button onclick="start()">開始</button>
    <button onclick="next()">下一步</button>
</div>

<script>
let array = [64, 34, 25, 12, 22, 11, 90];
let steps = [];
let currentStep = 0;

const container = document.getElementById("array-container");

function render(arr, active=[], sorted=[]) {
    container.innerHTML = "";
    arr.forEach((v, i) => {
        const bar = document.createElement("div");
        bar.className = "bar";
        bar.style.height = v * 3 + "px";
        bar.textContent = v;

        if (active.includes(i)) bar.classList.add("active");
        if (sorted.includes(i)) bar.classList.add("sorted");

        container.appendChild(bar);
    });
}

/* ===== Merge Sort 核心 ===== */

function mergeSort(arr, l, r) {
    if (l >= r) return;

    let mid = Math.floor((l + r) / 2);

    mergeSort(arr, l, mid);
    mergeSort(arr, mid + 1, r);

    merge(arr, l, mid, r);
}

function merge(arr, l, mid, r) {
    let left = arr.slice(l, mid + 1);
    let right = arr.slice(mid + 1, r + 1);

    let i = 0, j = 0, k = l;

    while (i < left.length && j < right.length) {
        steps.push({
            array: [...arr],
            active: [k]
        });

        if (left[i] <= right[j]) {
            arr[k++] = left[i++];
        } else {
            arr[k++] = right[j++];
        }

        steps.push({
            array: [...arr],
            active: [k-1]
        });
    }

    while (i < left.length) {
        arr[k++] = left[i++];
        steps.push({ array: [...arr], active: [k-1] });
    }

    while (j < right.length) {
        arr[k++] = right[j++];
        steps.push({ array: [...arr], active: [k-1] });
    }
}

/* ===== 控制 ===== */

function generateSteps() {
    let temp = [...array];
    steps = [];
    mergeSort(temp, 0, temp.length - 1);

    steps.push({
        array: [...temp],
        sorted: Array.from({length: temp.length}, (_, i) => i)
    });
}

function next() {
    if (currentStep < steps.length) {
        const s = steps[currentStep];
        render(s.array, s.active || [], s.sorted || []);
        currentStep++;
    }
}

function start() {
    currentStep = 0;
    generateSteps();
    next();
}

/* 初始化 */
render(array);

</script>
</body>
</html>